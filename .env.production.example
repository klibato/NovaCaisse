# ─── NovaCaisse — Production Environment Variables ───

# Database
DB_USER=novacaisse
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://novacaisse:CHANGE_ME@db:5432/novacaisse

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=GENERATE_A_RANDOM_64_CHAR_STRING

# Application
NODE_ENV=production
CORS_ORIGIN=https://*.novacaisse.fr
API_URL=https://api.novacaisse.fr
NEXT_PUBLIC_API_URL=https://api.novacaisse.fr

# Traefik / Let's Encrypt
LETSENCRYPT_EMAIL=contact@novacaisse.fr

# OVH DNS Challenge (pour wildcard *.novacaisse.fr)
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# Backup S3 (Scaleway Object Storage / AWS S3 / GCS)
S3_BUCKET=novacaisse-backups
S3_ENDPOINT=https://s3.fr-par.scw.cloud
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=fr-par

# Monitoring
DISCORD_WEBHOOK_URL=
ALERT_EMAIL=
